+/* MPEGTS_PROBE_SKIP_PNG: skip leading PNG (wrapper) before TS probe; bounded parse */
+#define MPEGTS_PROBE_SKIP_PNG_MAX 262144
+#define MPEGTS_PROBE_FIND_SYNC_MAX 65536
+
+static int mpegts_probe_skip_png_prefix(const uint8_t *buf, int size)
+{
+    static const uint8_t png_sig[8] = { 0x89, 'P', 'N', 'G', 0x0d, 0x0a, 0x1a, 0x0a };
+    int scan, pos, max_chunks = 64;
+    uint32_t chunk_len, tag;
+
+    if (!buf || size < 28)
+        return 0;
+    if (memcmp(buf, png_sig, 8))
+        return 0;
+
+    scan = FFMIN(size, MPEGTS_PROBE_SKIP_PNG_MAX);
+    pos = 8;
+    while (max_chunks-- > 0 && pos + 8 <= scan) {
+        chunk_len = AV_RB32(buf + pos);
+        tag       = AV_RB32(buf + pos + 4);
+        if (chunk_len > 100000000u)
+            return 0;
+        if (pos + 8 + (int)chunk_len + 4 > size)
+            return 0;
+        if (tag == MKTAG('I', 'E', 'N', 'D'))
+            return pos + 8 + (int)chunk_len + 4;
+        pos += 8 + (int)chunk_len + 4;
+    }
+    return 0;
+}
+
+/* Some anti-crawler variants append junk bytes after IEND, then TS packets. */
+static int mpegts_probe_sync_score(const uint8_t *buf, int size, int off, int step)
+{
+    int hits = 0, checks = 0, n;
+
+    for (n = 0; n < 8; n++) {
+        int pos = off + n * step;
+        if (pos >= size)
+            break;
+        checks++;
+        if (buf[pos] == 0x47)
+            hits++;
+    }
+
+    if (checks < 4)
+        return 0;
+    return hits * 10 / checks;
+}
+
+static int mpegts_probe_find_ts_sync(const uint8_t *buf, int size)
+{
+    int scan, off;
+    int best_off = 0, best_score = 0;
+
+    if (!buf || size < TS_PACKET_SIZE * 4)
+        return 0;
+
+    scan = FFMIN(size, MPEGTS_PROBE_FIND_SYNC_MAX);
+    for (off = 0; off + TS_PACKET_SIZE * 3 < scan; off++) {
+        int score;
+        if (buf[off] != 0x47)
+            continue;
+
+        score = FFMAX3(
+            mpegts_probe_sync_score(buf, scan, off, TS_PACKET_SIZE),
+            mpegts_probe_sync_score(buf, scan, off, TS_DVHS_PACKET_SIZE),
+            mpegts_probe_sync_score(buf, scan, off, TS_FEC_PACKET_SIZE)
+        );
+        if (score > best_score) {
+            best_score = score;
+            best_off = off;
+        }
+        if (score >= 8)
+            return off;
+    }
+
+    return best_score >= 7 ? best_off : 0;
+}
